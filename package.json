{
  "name": "ailatest-path",
  "version": "0.1.0",
  "private": true,
  "description": "Static school search database for affordable, legitimate U.S. study paths.",
  "type": "module",
  "scripts": {
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "build:experience-links": "node scripts/build-experience-links.js",
    "dev": "node scripts/dev.js",
    "deploy:domain": "npx --yes wrangler deploy --config wrangler.domain.jsonc",
    "import:scorecard": "node scripts/import-scorecard.js",
    "import:ipeds": "node scripts/not-implemented.js import:ipeds",
    "import:dapip": "node scripts/not-implemented.js import:dapip",
    "import:sevp": "node scripts/not-implemented.js import:sevp",
    "import:manual-programs": "node scripts/check.js",
    "summarize:reviews": "node scripts/check.js"
  },
  "engines": {
    "node": ">=20"
  }
}
